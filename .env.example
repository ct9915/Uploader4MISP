# Copy this file to .env and fill in the values.
# .env is listed in .gitignore and will never be committed.

# ── 環境模式 ──────────────────────────────────────────────────────────────────
# development（預設）或 production
FLASK_ENV=development

# ── Flask ─────────────────────────────────────────────────────────────────────
# 開發環境可使用任意字串；正式環境請使用強隨機字串
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# ── 應用程式 ──────────────────────────────────────────────────────────────────
PORT=5000

# ── Claude API（僅開發/測試時使用）──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SMTP 郵件設定（可於管理介面 Admin → Settings 覆蓋）────────────────────
# SMTP 伺服器位址
MAIL_SERVER=localhost
# SMTP 埠：25 = plain SMTP（公司內部常見）; 587 = STARTTLS; 465 = SSL
MAIL_PORT=25
# 是否使用 TLS（STARTTLS）；使用 port 25 時請設為 false
MAIL_USE_TLS=false
# SMTP 認證帳密（不需要認證時留空）
MAIL_USERNAME=
MAIL_PASSWORD=
# 寄件者地址
MAIL_SENDER=uploader4misp@localhost
