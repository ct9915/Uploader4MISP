# 正式環境 (Production) 設定範本
# 複製為 /opt/Uploader4MISP/.env 並填入實際值
# 此檔案不應 commit 至版本控制（已加入 .gitignore）

# ── 環境模式（必填） ──────────────────────────────────────────────────────────
FLASK_ENV=production

# ── Flask Secret Key（必填） ──────────────────────────────────────────────────
# 使用以下指令產生強隨機字串：
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=請替換為強隨機字串

# ── 應用程式埠號 ──────────────────────────────────────────────────────────────
# 若使用 nginx 反向代理，建議保持 5000（僅監聽 127.0.0.1）
PORT=5000
