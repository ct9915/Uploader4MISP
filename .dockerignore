.env
.env.*
*.env

# Runtime data (generated at container startup)
instance/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Docs / diagrams (not needed in image)
docs/

# Tests
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/

# Logs
*.log
logs/

# Node / frontend build artifacts (if any)
node_modules/
npm-debug.log

# Systemd unit (not needed in container)
*.service

# Docker files themselves
Dockerfile*
docker-compose*.yml
.dockerignore
k8s/
